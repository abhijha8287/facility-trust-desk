# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Databricks SQL Warehouse connection
DATABRICKS_SERVER_HOSTNAME=dbc-xxxxxxxx-xxxx.cloud.databricks.com
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Target catalog and schema for the two NEW tables
# (facility_reviews and facility_capability_scores)
TARGET_CATALOG=workspace
TARGET_SCHEMA=default

# LLM — OpenAI (default)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# To use Databricks Foundation Models instead, comment out OPENAI_API_KEY above
# and see the switchover comment in services/trust_engine.py
