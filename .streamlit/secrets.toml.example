# Copy this file to secrets.toml for local dev, OR paste these keys
# into Streamlit Cloud → App Settings → Secrets.
#
# For Streamlit Cloud deployment, do NOT upload secrets.toml —
# paste the values directly in the UI.

DATABRICKS_SERVER_HOSTNAME = "dbc-xxxxxxxx-xxxx.cloud.databricks.com"
DATABRICKS_HTTP_PATH       = "/sql/1.0/warehouses/xxxxxxxxxxxxxxxx"
DATABRICKS_TOKEN           = "dapixxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TARGET_CATALOG             = "workspace"
TARGET_SCHEMA              = "default"
OPENAI_API_KEY             = "sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
OPENAI_MODEL               = "gpt-4o-mini"
